# ──────────────────────────────────────────────────────────────────────────────
# Variables de entorno para desarrollo LOCAL
# Copia este archivo a .env.local y ajusta si es necesario.
# .env.local ya está en .gitignore — nunca subir al repo.
# ──────────────────────────────────────────────────────────────────────────────

# URL del backend local (servidor Flask en Docker)
VITE_API_URL=http://localhost:8000

# Cognito — en local usa valores de prueba (el backend los ignora con LOCAL_DEV=true)
# Si quieres probar el flujo real de Cognito, pon los valores reales de AWS aquí.
VITE_COGNITO_USER_POOL_ID=us-east-1_LOCALDEV
VITE_COGNITO_CLIENT_ID=localdevclientid
VITE_COGNITO_DOMAIN=auth.odontoval.com.ec

# Modo desarrollo: desactiva la verificación de Cognito en el frontend
VITE_LOCAL_DEV=true
